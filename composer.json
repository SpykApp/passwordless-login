{
    "name": "spykapps/passwordless-login",
    "description": "A highly customizable, multilingual magic link (passwordless) authentication package for Laravel with bot detection, rate limiting, and comprehensive event system.",
    "keywords": [
        "laravel",
        "passwordless",
        "magic-link",
        "authentication",
        "login",
        "passwordless-login",
        "magic-login"
    ],
    "homepage": "https://github.com/spykapps/passwordless-login",
    "license": "MIT",
    "authors": [
        {
            "name": "SpykApps",
            "email": "dev@spykapps.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/mail": "^10.0|^11.0|^12.0",
        "illuminate/notifications": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "SpykApp\\PasswordlessLogin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SpykApp\\PasswordlessLogin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SpykApp\\PasswordlessLogin\\PasswordlessLoginServiceProvider"
            ],
            "aliases": {
                "PasswordlessLogin": "SpykApp\\PasswordlessLogin\\Facades\\PasswordlessLogin"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
